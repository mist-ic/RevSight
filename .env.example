# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/revsight

# ─── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LITELLM_PRIMARY_MODEL=gpt-4o
LITELLM_FALLBACK_MODEL=claude-sonnet-4-5

# ─── Observability ────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=revsight
LOGFIRE_TOKEN=...

# ─── App Settings ─────────────────────────────────────────────────────────────
REQUIRE_APPROVAL=false
ENVIRONMENT=development
API_PORT=8000
FRONTEND_URL=http://localhost:3000
